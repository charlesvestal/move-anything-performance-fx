{
  "title": "Performance FX",
  "children": [
    {
      "title": "Getting Started",
      "lines": [
        "32 punch-in audio FX.",
        "Hold a pad = FX on.",
        "Release = FX off.",
        "Press harder for more!",
        "",
        "LAUNCH: Shift+Vol+Jog",
        "then select Performance FX",
        "",
        "TRY IT:",
        "1. Play something on Move",
        "2. Hold any pad - hear it!",
        "3. Press harder = more FX",
        "4. Shift+hold = latch on",
        "5. Turn knobs to tweak",
        "6. Back = save & exit"
      ]
    },
    {
      "title": "Pad Layout",
      "lines": [
        "All 32 pads are punch-in.",
        "Hold = on, release = off.",
        "Pressure controls the FX.",
        "",
        "Row 4 (orange): Time",
        "  1/4  1/8  1/16  Trip",
        "  Stut Scat Rev   Half",
        "",
        "Row 3 (blue): Filters",
        "  LP   HP   BPup BPdn",
        "  Reso Phas Flan Auto",
        "",
        "Row 2 (purple): Space",
        "  Dly  Ping Tape Frz",
        "  Verb Shim Dark Sprg",
        "",
        "Row 1 (green): Distort",
        "  Crsh Down Stop Vinyl",
        "  Sat  Duck Trem Chor"
      ]
    },
    {
      "title": "Latching",
      "lines": [
        "Any FX can be latched",
        "(stays on after release).",
        "",
        "LATCH: Shift + hold pad",
        "  Pad pulses = latched",
        "",
        "UNLATCH: Shift + hold",
        "  the latched pad again",
        "",
        "Multiple FX can be",
        "latched at once for",
        "layered effects."
      ]
    },
    {
      "title": "Knobs",
      "lines": [
        "Touch any knob to see",
        "what it controls.",
        "",
        "E1-E4: Last-touched FX",
        "  (4 params per FX)",
        "  Hold a pad, turn knobs",
        "  to shape the sound.",
        "",
        "E5: High-pass filter",
        "E6: Low-pass filter",
        "E7: Dry/Wet mix",
        "E8: EQ bump frequency",
        "",
        "Volume knob: host volume",
        "  (always pass-through)"
      ]
    },
    {
      "title": "Pressure",
      "lines": [
        "Each FX has its own",
        "pressure response:",
        "",
        "Repeats: pitch drift",
        "LP/HP sweep: sweep speed",
        "BP/Reso: resonance",
        "Phaser/Flanger: depth",
        "Delay: feedback amount",
        "Reverb: decay length",
        "Bitcrush: bit depth",
        "Tape stop: decel speed",
        "Saturate: drive amount",
        "Tremolo: depth",
        "",
        "All FX sound dramatic",
        "on tap - pressure adds",
        "extra dimension."
      ]
    },
    {
      "title": "Buttons",
      "lines": [
        "Undo: Bypass all FX",
        "  Tap = toggle on/off",
        "",
        "Jog click: Tap tempo",
        "  (tap 2+ times)",
        "Shift+Jog: Fine BPM",
        "",
        "Shift+Jog click: cycle",
        "  audio source",
        "  Line In > Move Mix >",
        "  Tracks",
        "",
        "Back: Save & exit"
      ]
    },
    {
      "title": "Scenes & Steps",
      "lines": [
        "16 scene snapshots store",
        "all FX latch states",
        "and parameters.",
        "",
        "Step buttons (bottom row)",
        "store FX snapshots.",
        "",
        "Tap step: recall preset",
        "Shift+step: save preset",
        "",
        "STEP SEQUENCER:",
        "Sequences through your",
        "step presets in time",
        "with the tempo."
      ]
    },
    {
      "title": "Tips",
      "lines": [
        "- Press harder for more!",
        "  Each FX responds to",
        "  pressure differently.",
        "",
        "- Latch multiple FX for",
        "  layered sound design",
        "",
        "- Filter sweeps animate",
        "  while held - try LP!",
        "",
        "- Space FX (row 2) have",
        "  natural tail decay",
        "  after release",
        "",
        "- State auto-saves every",
        "  10 seconds and on exit"
      ]
    }
  ]
}
