{
  "title": "Performance FX",
  "children": [
    {
      "title": "Getting Started",
      "lines": [
        "32 punch-in audio FX.",
        "Hold a pad = FX on.",
        "Release = FX off.",
        "Press harder for more!",
        "",
        "LAUNCH: Shift+Vol+Jog",
        "then select Performance FX",
        "",
        "TRY IT:",
        "1. Play something on Move",
        "2. Hold any pad - hear it!",
        "3. Press harder = more FX",
        "4. Shift+hold = latch on",
        "5. Turn knobs to tweak",
        "6. Back = exit"
      ]
    },
    {
      "title": "Pad Layout",
      "lines": [
        "All 32 pads are punch-in.",
        "Hold = on, release = off.",
        "Pressure controls the FX.",
        "",
        "Row 4 (orange): Time",
        "  1/4  1/8  1/16  Trip",
        "  Stut Scat Rev   Strch",
        "",
        "Row 3 (blue): Filters",
        "  LP   HP   BPup BPdn",
        "  Reso Phas Flan Auto",
        "",
        "Row 2 (purple): Space",
        "  Dly  DlyD PP   PPD",
        "  Room Hall Dark Sprg",
        "",
        "Row 1 (mixed): Distort",
        "  Crsh Down Sat  Gate",
        "  Trem Oct  Vnyl VnBk"
      ]
    },
    {
      "title": "Latching",
      "lines": [
        "Any FX can be latched",
        "(stays on after release).",
        "",
        "LATCH: Shift + hold pad",
        "  Pad pulses = latched",
        "",
        "UNLATCH: Shift + hold",
        "  the latched pad again",
        "",
        "Multiple FX can be",
        "latched at once for",
        "layered effects."
      ]
    },
    {
      "title": "Knobs",
      "lines": [
        "Touch any knob to see",
        "what it controls.",
        "",
        "E1: Repeat Length",
        "E2: Repeat Speed",
        "E3: Repeat On/Off",
        "  (turn right=on, left=off)",
        "E4-E6: Per-FX params",
        "  (last touched pad)",
        "E7: Tilt EQ",
        "E8: DJ Filter",
        "",
        "Volume knob: host volume",
        "  (always pass-through)"
      ]
    },
    {
      "title": "Pressure",
      "lines": [
        "Each FX has its own",
        "pressure response:",
        "",
        "Repeats: pitch drift",
        "LP/HP sweep: sweep speed",
        "BP/Reso: resonance",
        "Phaser/Flanger: depth",
        "Delay: feedback amount",
        "Reverb: decay length",
        "Bitcrush: bit depth",
        "Saturate: drive amount",
        "Tremolo: depth",
        "",
        "All FX sound dramatic",
        "on tap - pressure adds",
        "extra dimension."
      ]
    },
    {
      "title": "Bypass",
      "lines": [
        "Undo button: Bypass",
        "  Tap = toggle on/off",
        "",
        "When bypassed, audio",
        "passes through dry.",
        "All FX remain in their",
        "current state but are",
        "silenced until bypass",
        "is toggled off."
      ]
    },
    {
      "title": "Other Controls",
      "lines": [
        "Jog click: Tap tempo",
        "  (tap 2+ times)",
        "",
        "Shift+Jog turn:",
        "  Fine BPM adjustment",
        "",
        "Undo: Bypass toggle",
        "  Tap = bypass on/off",
        "",
        "Back: Exit PFX"
      ]
    },
    {
      "title": "Tips",
      "lines": [
        "- Press harder for more!",
        "  Each FX responds to",
        "  pressure differently.",
        "",
        "- Latch multiple FX for",
        "  layered sound design",
        "",
        "- Filter sweeps animate",
        "  while held - try LP!",
        "",
        "- Space FX (row 2) have",
        "  natural tail decay",
        "  after release",
        "",
        "- Repeat rate knob",
        "  changes take effect",
        "  immediately"
      ]
    }
  ]
}
